const STORAGE_KEY = "skyline-zero-scores";

const dashboardEl = document.querySelector("#dashboard");
const leaderboardEl = document.querySelector("#leaderboard");
const canvas = document.querySelector("#game-canvas");
const ctx = canvas.getContext("2d");
const overlay = document.querySelector("#overlay");
const scoreForm = document.querySelector("#score-form");
const finalScoreLabel = document.querySelector("#final-score-label");
const finalScoreCopy = document.querySelector("#final-score-copy");
const playerNameInput = document.querySelector("#player-name");
const hudSpeed = document.querySelector("#hud-speed");
const hudDash = document.querySelector("#hud-dash");
const shareBtn = document.querySelector("#share-btn");

const state = {
  scores: [],
  started: false,
  gameOver: false,
  scoreSubmitted: false,
  lastTime: 0,
  score: 0,
  combo: 0,
  maxCombo: 0,
  runTimeMs: 0,
  worldSpeed: 1,
  dashCooldown: 0,
  shieldTime: 0,
  slowTime: 0,
  flash: 0,
  droneTimer: 0,
  pickupTimer: 0,
  player: {
    x: canvas.width / 2,
    y: canvas.height - 140,
    width: 54,
    height: 76,
    speed: 430,
    dashTime: 0,
  },
  keys: {
    left: false,
    right: false,
  },
  drones: [],
  pickups: [],
  particles: [],
};

document.querySelector("#start-btn").addEventListener("click", startGame);
document.querySelector("#restart-btn").addEventListener("click", restartGame);
document.querySelector("#clear-scores-btn").addEventListener("click", clearScores);
scoreForm.addEventListener("submit", saveScore);
shareBtn.addEventListener("click", copyBragText);

window.addEventListener("keydown", (event) => {
  if (event.key === "ArrowLeft" || event.key.toLowerCase() === "a") {
    state.keys.left = true;
  }
  if (event.key === "ArrowRight" || event.key.toLowerCase() === "d") {
    state.keys.right = true;
  }
  if (event.code === "Space") {
    event.preventDefault();
    if (!state.started) {
      startGame();
      return;
    }
    triggerDash();
  }
});

window.addEventListener("keyup", (event) => {
  if (event.key === "ArrowLeft" || event.key.toLowerCase() === "a") {
    state.keys.left = false;
  }
  if (event.key === "ArrowRight" || event.key.toLowerCase() === "d") {
    state.keys.right = false;
  }
});

boot();

function boot() {
  state.scores = loadScores();
  renderLeaderboard();
  renderDashboard();
  requestAnimationFrame(loop);
}

function loadScores() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    const parsed = raw ? JSON.parse(raw) : [];
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return [];
  }
}

function persistScores() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(state.scores.slice(0, 10)));
}

function renderDashboard() {
  const bestScore = state.scores[0]?.score ?? 0;
  const metrics = [
    {
      label: "Top score",
      value: bestScore,
      subtext: "The number everyone else on this browser is chasing.",
    },
    {
      label: "Current combo",
      value: `x${Math.max(1, state.combo)}`,
      subtext: "Spark chains make your score spike fast.",
    },
    {
      label: "Run timer",
      value: `${(state.runTimeMs / 1000).toFixed(1)}s`,
      subtext: "Stay alive longer and the skyline turns vicious.",
    },
    {
      label: "Live score",
      value: Math.floor(state.score),
      subtext: "Every clean dodge buys more points and pressure.",
    },
  ];

  dashboardEl.innerHTML = "";
  const template = document.querySelector("#metric-template");
  metrics.forEach((metric, index) => {
    const fragment = template.content.cloneNode(true);
    fragment.querySelector(".metric-label").textContent = metric.label;
    fragment.querySelector(".metric-value").textContent = metric.value;
    fragment.querySelector(".metric-subtext").textContent = metric.subtext;
    fragment.querySelector(".metric-card").style.animationDelay = `${index * 60}ms`;
    dashboardEl.appendChild(fragment);
  });
}

function renderLeaderboard() {
  leaderboardEl.innerHTML = "";
  if (!state.scores.length) {
    leaderboardEl.innerHTML = `
      <article class="leaderboard-row">
        <div>
          <div class="panel-kicker">No runs yet</div>
          <p>Be the first pilot on the board.</p>
        </div>
      </article>
    `;
    return;
  }

  state.scores.forEach((entry, index) => {
    const row = document.createElement("article");
    row.className = "leaderboard-row";
    row.innerHTML = `
      <div>
        <div class="rank-pill">#${index + 1}</div>
        <h3>${escapeHtml(entry.name)}</h3>
        <p>Combo x${entry.maxCombo} • ${(entry.durationMs / 1000).toFixed(1)}s survival</p>
      </div>
      <strong>${entry.score}</strong>
    `;
    leaderboardEl.appendChild(row);
  });
}

function startGame() {
  if (!state.started) {
    resetRun();
  }
  state.started = true;
  state.gameOver = false;
  overlay.classList.add("hidden");
}

function restartGame() {
  resetRun();
  state.started = true;
  overlay.classList.add("hidden");
}

function resetRun() {
  state.started = true;
  state.gameOver = false;
  state.scoreSubmitted = false;
  state.score = 0;
  state.combo = 0;
  state.maxCombo = 0;
  state.runTimeMs = 0;
  state.worldSpeed = 1;
  state.dashCooldown = 0;
  state.shieldTime = 0;
  state.slowTime = 0;
  state.flash = 0;
  state.droneTimer = 0;
  state.pickupTimer = 0;
  state.player.x = canvas.width / 2;
  state.player.dashTime = 0;
  state.drones = [];
  state.pickups = [];
  state.particles = [];
  playerNameInput.value = "";
  finalScoreCopy.textContent = "You hit the skyline hard. Queue another run.";
  shareBtn.textContent = "Copy brag text";
  updateHud();
  renderDashboard();
}

function loop(timestamp) {
  const dt = Math.min(32, timestamp - (state.lastTime || timestamp)) / 1000;
  state.lastTime = timestamp;
  update(dt);
  render();
  requestAnimationFrame(loop);
}

function update(dt) {
  if (!state.started || state.gameOver) {
    if (state.flash > 0) {
      state.flash = Math.max(0, state.flash - dt * 2);
    }
    return;
  }

  state.runTimeMs += dt * 1000;
  state.worldSpeed = 1 + Math.min(2.2, state.runTimeMs / 18000);
  state.dashCooldown = Math.max(0, state.dashCooldown - dt);
  state.player.dashTime = Math.max(0, state.player.dashTime - dt);
  state.shieldTime = Math.max(0, state.shieldTime - dt);
  state.slowTime = Math.max(0, state.slowTime - dt);
  state.flash = Math.max(0, state.flash - dt * 3);

  const speedFactor = state.slowTime > 0 ? 0.6 : 1;
  const moveSpeed = state.player.speed * (state.player.dashTime > 0 ? 1.8 : 1) * dt;
  if (state.keys.left) {
    state.player.x -= moveSpeed;
  }
  if (state.keys.right) {
    state.player.x += moveSpeed;
  }
  state.player.x = clamp(state.player.x, 64, canvas.width - 64);

  maybeSpawnDrone(dt, speedFactor);
  maybeSpawnPickup(dt, speedFactor);
  updateEntities(dt);

  state.score += dt * 110 * state.worldSpeed + state.combo * dt * 6;
  renderDashboard();
  updateHud();
}

function maybeSpawnDrone(dt, speedFactor) {
  state.droneTimer -= dt;
  if (state.droneTimer > 0) {
    return;
  }
  state.droneTimer = Math.max(0.18, 0.65 - state.worldSpeed * 0.09);
  state.drones.push({
    x: randomBetween(80, canvas.width - 80),
    y: -140,
    width: randomBetween(60, 120),
    height: randomBetween(40, 90),
    speed: randomBetween(280, 420) * state.worldSpeed * speedFactor,
    drift: randomBetween(-45, 45),
  });
}

function maybeSpawnPickup(dt, speedFactor) {
  state.pickupTimer -= dt;
  if (state.pickupTimer > 0) {
    return;
  }
  state.pickupTimer = randomBetween(0.9, 1.8);
  const roll = Math.random();
  const kind = roll > 0.88 ? "shield" : roll > 0.75 ? "slow" : "spark";
  state.pickups.push({
    kind,
    x: randomBetween(70, canvas.width - 70),
    y: -60,
    radius: kind === "spark" ? 14 : 18,
    speed: randomBetween(230, 320) * state.worldSpeed * speedFactor,
  });
}

function updateEntities(dt) {
  const playerRect = {
    x: state.player.x - state.player.width / 2,
    y: state.player.y - state.player.height / 2,
    width: state.player.width,
    height: state.player.height,
  };

  state.drones = state.drones.filter((drone) => {
    drone.y += drone.speed * dt;
    drone.x += drone.drift * dt;
    drone.x = clamp(drone.x, 50, canvas.width - 50);

    if (intersects(playerRect, drone)) {
      if (state.shieldTime > 0) {
        state.shieldTime = 0;
        state.flash = 1;
        burst(drone.x, drone.y, "#d6ff72");
        return false;
      }
      endRun();
      return false;
    }

    return drone.y < canvas.height + 120;
  });

  state.pickups = state.pickups.filter((pickup) => {
    pickup.y += pickup.speed * dt;
    const distance = Math.hypot(pickup.x - state.player.x, pickup.y - state.player.y);
    if (distance < pickup.radius + 28) {
      collectPickup(pickup);
      return false;
    }
    return pickup.y < canvas.height + 80;
  });

  state.particles = state.particles.filter((particle) => {
    particle.x += particle.vx * dt;
    particle.y += particle.vy * dt;
    particle.life -= dt;
    return particle.life > 0;
  });
}

function collectPickup(pickup) {
  if (pickup.kind === "spark") {
    state.combo += 1;
    state.maxCombo = Math.max(state.maxCombo, state.combo);
    state.score += 80 + state.combo * 25;
    burst(pickup.x, pickup.y, "#53d7d6");
    return;
  }

  if (pickup.kind === "shield") {
    state.shieldTime = 4.2;
    state.score += 120;
    burst(pickup.x, pickup.y, "#d6ff72");
    return;
  }

  state.slowTime = 3.2;
  state.score += 90;
  burst(pickup.x, pickup.y, "#ffad42");
}

function triggerDash() {
  if (!state.started || state.gameOver || state.dashCooldown > 0) {
    return;
  }
  state.player.dashTime = 0.22;
  state.dashCooldown = 1.8;
  burst(state.player.x, state.player.y, "#ff845a");
}

function endRun() {
  state.gameOver = true;
  state.started = false;
  state.combo = 0;
  finalScoreLabel.textContent = `${Math.floor(state.score)} pts`;
  finalScoreCopy.textContent = `Top combo x${state.maxCombo} • ${(state.runTimeMs / 1000).toFixed(1)}s in the zone.`;
  overlay.classList.remove("hidden");
  updateHud();
}

function saveScore(event) {
  event.preventDefault();
  if (state.scoreSubmitted) {
    return;
  }
  const entry = {
    name: cleanName(playerNameInput.value),
    score: Math.floor(state.score),
    maxCombo: state.maxCombo,
    durationMs: Math.floor(state.runTimeMs),
  };
  state.scores.push(entry);
  state.scores.sort((a, b) => b.score - a.score || b.maxCombo - a.maxCombo || b.durationMs - a.durationMs);
  state.scores = state.scores.slice(0, 10);
  persistScores();
  state.scoreSubmitted = true;
  renderLeaderboard();
  renderDashboard();
  finalScoreCopy.textContent = "Score saved locally. Queue another run.";
}

function clearScores() {
  state.scores = [];
  localStorage.removeItem(STORAGE_KEY);
  renderLeaderboard();
  renderDashboard();
}

async function copyBragText() {
  const text = `I scored ${Math.floor(state.score)} in Skyline Zero with a max combo of x${state.maxCombo}.`;
  try {
    if (navigator.share) {
      await navigator.share({ title: "Skyline Zero", text });
    } else if (navigator.clipboard) {
      await navigator.clipboard.writeText(text);
    }
    shareBtn.textContent = "Brag text ready";
  } catch {
    shareBtn.textContent = "Copy failed";
  }
}

function updateHud() {
  hudSpeed.textContent = `Speed ${state.worldSpeed.toFixed(1)}x`;
  hudDash.textContent = state.dashCooldown > 0 ? `Dash ${state.dashCooldown.toFixed(1)}s` : "Dash ready";
}

function render() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  drawBackground();
  drawLanes();
  drawPickups();
  drawDrones();
  drawPlayer();
  drawParticles();
  drawHud();
}

function drawBackground() {
  const gradient = ctx.createLinearGradient(0, 0, 0, canvas.height);
  gradient.addColorStop(0, "#08121b");
  gradient.addColorStop(1, "#0e1c28");
  ctx.fillStyle = gradient;
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  for (let i = 0; i < 12; i += 1) {
    const height = 120 + (i % 3) * 60;
    const x = i * 64;
    ctx.fillStyle = "rgba(255, 255, 255, 0.03)";
    ctx.fillRect(x, canvas.height - height, 40, height);
  }
}

function drawLanes() {
  ctx.strokeStyle = "rgba(83, 215, 214, 0.18)";
  ctx.lineWidth = 2;
  for (let lane = 1; lane < 4; lane += 1) {
    const x = (canvas.width / 5) * lane;
    ctx.setLineDash([14, 18]);
    ctx.beginPath();
    ctx.moveTo(x, 0);
    ctx.lineTo(x, canvas.height);
    ctx.stroke();
  }
  ctx.setLineDash([]);
}

function drawPlayer() {
  const { x, y, width, height } = state.player;
  ctx.save();
  ctx.translate(x, y);
  ctx.shadowBlur = state.player.dashTime > 0 ? 34 : 22;
  ctx.shadowColor = state.shieldTime > 0 ? "#d6ff72" : "#ff845a";
  ctx.fillStyle = state.shieldTime > 0 ? "#d6ff72" : "#ff845a";
  ctx.beginPath();
  ctx.moveTo(0, -height / 2);
  ctx.lineTo(width / 2, height / 2);
  ctx.lineTo(0, height / 4);
  ctx.lineTo(-width / 2, height / 2);
  ctx.closePath();
  ctx.fill();
  ctx.fillStyle = "#09131c";
  ctx.fillRect(-7, -2, 14, 18);
  ctx.restore();
}

function drawDrones() {
  state.drones.forEach((drone) => {
    ctx.save();
    ctx.translate(drone.x, drone.y);
    ctx.fillStyle = "#ff6b76";
    ctx.shadowBlur = 28;
    ctx.shadowColor = "#ff6b76";
    roundRect(ctx, -drone.width / 2, -drone.height / 2, drone.width, drone.height, 18);
    ctx.fill();
    ctx.fillStyle = "rgba(9, 19, 28, 0.7)";
    roundRect(ctx, -drone.width / 3, -drone.height / 4, drone.width / 1.5, drone.height / 2, 14);
    ctx.fill();
    ctx.restore();
  });
}

function drawPickups() {
  state.pickups.forEach((pickup) => {
    ctx.save();
    ctx.translate(pickup.x, pickup.y);
    const color = pickup.kind === "spark" ? "#53d7d6" : pickup.kind === "shield" ? "#d6ff72" : "#ffad42";
    ctx.fillStyle = color;
    ctx.shadowBlur = 26;
    ctx.shadowColor = color;
    ctx.beginPath();
    ctx.arc(0, 0, pickup.radius, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
  });
}

function drawParticles() {
  state.particles.forEach((particle) => {
    ctx.save();
    ctx.globalAlpha = Math.max(0, particle.life * 1.2);
    ctx.fillStyle = particle.color;
    ctx.fillRect(particle.x, particle.y, 4, 4);
    ctx.restore();
  });
}

function drawHud() {
  ctx.save();
  ctx.fillStyle = "rgba(255, 255, 255, 0.88)";
  ctx.font = "700 28px 'Bahnschrift', sans-serif";
  ctx.fillText(`Score ${Math.floor(state.score)}`, 24, 42);
  ctx.font = "600 20px 'Aptos', sans-serif";
  ctx.fillStyle = "rgba(255, 255, 255, 0.72)";
  ctx.fillText(`Combo x${Math.max(1, state.combo)}`, 24, 72);
  if (!state.started && !state.gameOver) {
    ctx.textAlign = "center";
    ctx.font = "700 34px 'Bahnschrift', sans-serif";
    ctx.fillStyle = "rgba(244, 247, 250, 0.94)";
    ctx.fillText("Press Launch Run", canvas.width / 2, canvas.height / 2);
    ctx.font = "600 18px 'Aptos', sans-serif";
    ctx.fillStyle = "rgba(145, 168, 183, 0.94)";
    ctx.fillText("Use movement keys. Space gives you a short dash.", canvas.width / 2, canvas.height / 2 + 34);
  }
  if (state.flash > 0) {
    ctx.globalAlpha = state.flash * 0.16;
    ctx.fillStyle = "#d6ff72";
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  }
  ctx.restore();
}

function burst(x, y, color) {
  for (let i = 0; i < 18; i += 1) {
    state.particles.push({
      x,
      y,
      vx: randomBetween(-140, 140),
      vy: randomBetween(-140, 140),
      life: randomBetween(0.3, 0.8),
      color,
    });
  }
}

function randomBetween(min, max) {
  return Math.random() * (max - min) + min;
}

function clamp(value, min, max) {
  return Math.max(min, Math.min(max, value));
}

function cleanName(value) {
  const trimmed = String(value || "").trim();
  return trimmed ? trimmed.slice(0, 22) : "Anonymous Pilot";
}

function intersects(a, b) {
  return (
    a.x < b.x + b.width / 2 &&
    a.x + a.width > b.x - b.width / 2 &&
    a.y < b.y + b.height / 2 &&
    a.y + a.height > b.y - b.height / 2
  );
}

function roundRect(context, x, y, width, height, radius) {
  context.beginPath();
  context.moveTo(x + radius, y);
  context.arcTo(x + width, y, x + width, y + height, radius);
  context.arcTo(x + width, y + height, x, y + height, radius);
  context.arcTo(x, y + height, x, y, radius);
  context.arcTo(x, y, x + width, y, radius);
  context.closePath();
}

function escapeHtml(value) {
  return String(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}
